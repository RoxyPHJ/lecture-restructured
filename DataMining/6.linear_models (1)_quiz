    // Essay: no auto-grade
    q22: null, q23: null, q24: null, q25: null
  };

  const userAnswers = {};
  let graded = false;

  // ── 선택 함수 ──
  function selectOX(btn) {
    if (graded) return;
    const q = btn.dataset.q;
    const siblings = btn.parentElement.querySelectorAll('.ox-btn');
    siblings.forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    userAnswers['q' + q] = btn.dataset.val;
    updateProgress();
  }

  function selectMC(btn) {
    if (graded) return;
    const q = btn.dataset.q;
    const siblings = btn.parentElement.querySelectorAll('.mc-opt');
    siblings.forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    userAnswers['q' + q] = btn.dataset.val;
    updateProgress();
  }

  // ── 정답 토글 ──
  function toggleAnswer(id, btn) {
    const box = document.getElementById(id);
    box.classList.toggle('visible');
    btn.classList.toggle('open');
