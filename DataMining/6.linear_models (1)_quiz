      // 단답형 (18~21)
      if (i >= 18 && i <= 21) {
        const inp = document.getElementById('i' + i);
        const val = inp ? inp.value.trim().toLowerCase() : '';
        inp.disabled = true;
        const keywords = ca; // array
        const isCorrect = keywords.some(k => val.includes(k.toLowerCase()));
        if (!ua && !val) {
          skip++;
          ri.textContent = '—';
          ri.style.display = 'block';
          ri.style.color = 'var(--text3)';
        } else if (isCorrect) {
          correct++;
          inp.classList.add('correct');
          card.classList.add('answered-correct');
          ri.textContent = '✓';
          ri.style.color = 'var(--green)';
          ri.style.display = 'block';
        } else {
          wrong++;
          inp.classList.add('wrong');
          card.classList.add('answered-wrong');
          ri.textContent = '✗';
          ri.style.color = 'var(--red)';
          ri.style.display = 'block';
          // 자동으로 해설 표시
          const togBtn = card.querySelector('.answer-toggle');
          const box = card.querySelector('.answer-box');
