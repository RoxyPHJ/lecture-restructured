  function markCorrect(qid, val) {
    const card = document.getElementById(qid);
    // OX
    card.querySelectorAll('.ox-btn').forEach(b => {
      if (b.dataset.val === val) b.classList.add('correct');
    });
    // MC
    card.querySelectorAll('.mc-opt').forEach(b => {
      if (b.dataset.val === val) b.classList.add('correct');
    });
  }

  function markWrong(qid, userVal, correctVal) {
    const card = document.getElementById(qid);
    // OX
    card.querySelectorAll('.ox-btn').forEach(b => {
      if (b.dataset.val === userVal) b.classList.add('wrong');
      if (b.dataset.val === correctVal) b.classList.add('show-correct');
    });
    // MC
    card.querySelectorAll('.mc-opt').forEach(b => {
      if (b.dataset.val === userVal) b.classList.add('wrong');
      if (b.dataset.val === correctVal) b.classList.add('show-correct');
    });
  }

  // ── 초기화 ──
  function resetAll() {
    graded = false;
    for (const key in userAnswers) delete userAnswers[key];

    document.querySelectorAll('.q-card').forEach(c => {
      c.classList.remove('answered-correct', 'answered-wrong');
      c.style.borderColor = '';
    });
    document.querySelectorAll('.ox-btn').forEach(b => {
      b.classList.remove('selected', 'correct', 'wrong', 'show-correct');
    });
    document.querySelectorAll('.mc-opt').forEach(b => {
      b.classList.remove('selected', 'correct', 'wrong', 'show-correct');
    });
    document.querySelectorAll('.sa-input, .essay-input').forEach(el => {
      el.value = '';
      el.disabled = false;
      el.classList.remove('correct', 'wrong');
    });
    document.querySelectorAll('.answer-box').forEach(b => b.classList.remove('visible'));
    document.querySelectorAll('.answer-toggle').forEach(b => {
      b.classList.remove('open');
      const arr = b.querySelector('.arrow');
      if (arr) arr.textContent = '▶';
    });
    document.querySelectorAll('.result-icon').forEach(r => {
      r.style.display = 'none';
      r.textContent = '';
    });
    document.getElementById('resultBanner').classList.remove('visible');
    document.getElementById('scoreVal').textContent = '—';
    document.getElementById('progressFill').style.width = '0%';
  }
</script>
</body>
</html>
